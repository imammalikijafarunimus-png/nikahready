# ============================================================
# NikahReady — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App URL (for OpenGraph metadata) ─────────────────────────
NEXT_PUBLIC_APP_URL=https://nikahready.vercel.app

# ── Payment / Bank Info (untuk halaman Upgrade) ───────────────
# Diisi di Vercel > Settings > Environment Variables
# PENTING: Setelah mengubah env vars di Vercel, harus REDEPLOY!
NEXT_PUBLIC_WA_NUMBER=6281234567890
NEXT_PUBLIC_BANK_NAME=BSI
NEXT_PUBLIC_BANK_ACC=1234567890
NEXT_PUBLIC_BANK_HOLDER=Nama Pemilik Rekening
NEXT_PUBLIC_QRIS_ACTIVE=true
NEXT_PUBLIC_PRO_PRICE=49.000

# ── Optional: Plan default for new users ──────────────────────
# FREE  = 7 steps, 1 template
# PREMIUM = 22 steps, 3 templates
NEXT_PUBLIC_DEFAULT_PLAN=premium